# Database Configuration
DATABASE_HOST=your_tidb_host.tidbcloud.com
DATABASE_USER=root
DATABASE_PASSWORD=your_tidb_password
DATABASE_NAME=event_manager
DATABASE_PORT=4000

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secrets (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=your_secure_jwt_access_secret_here_32_chars_minimum
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_here_32_chars_minimum
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Cerebras AI Configuration
CEREBRAS_API_KEY_1=your_cerebras_api_key_1
CEREBRAS_API_KEY_2=your_cerebras_api_key_2
CEREBRAS_API_KEY_3=your_cerebras_api_key_3
CEREBRAS_API_KEY_4=your_cerebras_api_key_4
CEREBRAS_API_KEY_5=your_cerebras_api_key_5
CEREBRAS_API_KEY_6=your_cerebras_api_key_6

# Cloudinary Configuration (Document & Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (Optional - for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Client Configuration
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
CSRF_TOKEN_LENGTH=32
SESSION_SECRET=your_session_secret_here

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# External Services API Endpoints
CEREBRAS_API_BASE=https://api.cerebras.ai/v1
