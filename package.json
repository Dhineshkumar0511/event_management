{
  "name": "eventpass",
  "version": "1.0.0",
  "description": "Smart OD Letter Management System for College Events",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "db:migrate": "node server/database/migrate.js",
    "db:seed": "node server/database/seed.js"
  },
  "keywords": [
    "od-letter",
    "event-management",
    "college",
    "hackathon"
  ],
  "author": "EventPass Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.9.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9",
    "openai": "^4.28.0",
    "pdfkit": "^0.15.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "axios": "^1.13.6",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
